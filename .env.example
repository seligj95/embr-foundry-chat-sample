# Foundry configuration (OpenAI-compatible endpoint).
# Get these from the Azure AI Foundry portal — see README for full steps.
#
# Base URL: your model deployment's Target URI with the trailing /responses
# suffix removed, e.g.:
#   https://<resource>.services.ai.azure.com/api/projects/<project>/openai/v1
FOUNDRY_BASE_URL=https://<resource>.services.ai.azure.com/api/projects/<project>/openai/v1
# API key for the resource (Keys + Endpoint on the Foundry resource page).
FOUNDRY_API_KEY=<your-key>
# Name of the deployment you created, e.g. gpt-4o-mini, gpt-5.4-mini-1.
FOUNDRY_MODEL_DEPLOYMENT=<your-deployment-name>
